<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Color palette -->
  <Color x:Key="ColorPrimaryDark">#FF0F172A</Color>
  <Color x:Key="ColorSecondary">#FF1E293B</Color>
  <Color x:Key="ColorAccent">#FF334155</Color>
  <Color x:Key="ColorButtonHover">#FF475569</Color>
  <Color x:Key="ColorAltRow">#FF162032</Color>
  <Color x:Key="ColorSelectedRow">#FF334155</Color>
  <Color x:Key="ColorPrimaryText">#FFF1F5F9</Color>
  <Color x:Key="ColorSecondaryText">#FF94A3B8</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="BrushPrimaryDark" Color="{StaticResource ColorPrimaryDark}" />
  <SolidColorBrush x:Key="BrushSecondary" Color="{StaticResource ColorSecondary}" />
  <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
  <SolidColorBrush x:Key="BrushButtonHover" Color="{StaticResource ColorButtonHover}" />
  <SolidColorBrush x:Key="BrushAltRow" Color="{StaticResource ColorAltRow}" />
  <SolidColorBrush x:Key="BrushSelectedRow" Color="{StaticResource ColorSelectedRow}" />
  <SolidColorBrush x:Key="BrushPrimaryText" Color="{StaticResource ColorPrimaryText}" />
  <SolidColorBrush x:Key="BrushSecondaryText" Color="{StaticResource ColorSecondaryText}" />

  <!-- Header gradient -->
  <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{StaticResource ColorPrimaryDark}" Offset="0" />
    <GradientStop Color="{StaticResource ColorSecondary}" Offset="1" />
  </LinearGradientBrush>

  <!-- Window background -->
  <Style TargetType="Window">
    <Setter Property="Background" Value="{StaticResource BrushPrimaryDark}" />
    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
  </Style>

  <!-- Panels / Containers -->
  <Style TargetType="Panel">
    <Setter Property="Background" Value="{StaticResource BrushPrimaryDark}" />
  </Style>

  <!-- Menu Bar -->
  <Style TargetType="Menu">
    <Setter Property="Background" Value="{StaticResource BrushSecondary}" />
    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
    <Setter Property="Background" Value="Transparent" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="#FF334155" />
      </Trigger>
      <Trigger Property="IsSubmenuOpen" Value="True">
        <Setter Property="Background" Value="#FF334155" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- TextBlock default text colors -->
  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
  </Style>

  <!-- Labels / Secondary text -->
  <Style TargetType="Label">
    <Setter Property="Foreground" Value="{StaticResource BrushSecondaryText}" />
  </Style>

  <!-- Buttons: only change background and foreground, preserve templates and sizing -->
  <Style TargetType="Button">
    <Setter Property="Background" Value="{StaticResource BrushAccent}" />
    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{StaticResource BrushButtonHover}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- DataGrid styling -->
  <Style TargetType="DataGrid">
    <Setter Property="Background" Value="{StaticResource BrushPrimaryDark}" />
    <Setter Property="RowBackground" Value="{StaticResource BrushSecondary}" />
    <Setter Property="AlternatingRowBackground" Value="{StaticResource BrushAltRow}" />
    <Setter Property="GridLinesVisibility" Value="Vertical" />
    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="{StaticResource BrushAccent}" />
    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
  </Style>

  <Style TargetType="DataGridRow">
    <!-- Provide equal top and bottom padding for rows -->
    <Setter Property="Padding" Value="4,6" />
    <Style.Triggers>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{StaticResource BrushSelectedRow}" />
        <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <!-- TextBox styling -->
  <Style TargetType="TextBox">
    <Setter Property="Padding" Value="8,6,8,6" />
    <Setter Property="Background" Value="{StaticResource BrushSecondary}" />
    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}" />
    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
    <Style.Triggers>
      <Trigger Property="IsKeyboardFocused" Value="True">
        <Setter Property="BorderBrush" Value="{StaticResource BrushSelectedRow}" />
      </Trigger>
    </Style.Triggers>
  </Style>

</ResourceDictionary>
