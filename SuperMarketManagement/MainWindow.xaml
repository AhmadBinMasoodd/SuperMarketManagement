<Window x:Class="SuperMarketManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SuperStore Login"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="980"
        MinHeight="620"
        Background="{StaticResource BrushPrimaryDark}">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource BrushButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource BrushAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
            Background="{StaticResource HeaderGradient}"
                CornerRadius="0,28,28,0"
                Padding="36">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="SuperStore"
                           Foreground="{StaticResource BrushPrimaryText}"
                           FontSize="38"
                           FontWeight="Bold"/>
                <TextBlock Text="Management System"
                           Foreground="{StaticResource BrushSecondaryText}"
                           FontSize="22"
                           Margin="0,4,0,0"/>
                <TextBlock Text="Secure access for Admin and Manager modules."
                           Foreground="{StaticResource BrushSecondaryText}"
                           FontSize="14"
                           Margin="0,20,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Border Width="430"
                    MaxWidth="460"
                    MinWidth="360"
                    Background="{StaticResource BrushSecondary}"
                    BorderBrush="{StaticResource BrushAccent}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Welcome Back"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Login to continue"
                               FontSize="13"
                               Foreground="{StaticResource BrushSecondaryText}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,22"/>

                    <TextBlock Text="Email"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushSecondaryText}"/>
                    <TextBox x:Name="EmailBox"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Height="38"
                             VerticalContentAlignment="Center"
                             Margin="0,6,0,12"
                             Padding="8,6,8,6"
                             BorderBrush="{StaticResource BrushAccent}"
                             BorderThickness="1"
                             Background="{StaticResource BrushSecondary}"
                             Foreground="{StaticResource BrushPrimaryText}"/>

                    <TextBlock Text="Password"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushSecondaryText}"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Height="38"
                                 Margin="0,6,0,18"
                                 Padding="8,6,8,6"
                                 BorderBrush="{StaticResource BrushAccent}"
                                 BorderThickness="1"
                                 Background="{StaticResource BrushSecondary}"
                                 Foreground="{StaticResource BrushPrimaryText}"/>

                    <Button Content="Login"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{Binding ElementName=PasswordBox}"/>

                    <TextBlock x:Name="ErrorText"
                               Text="{Binding ErrorMessage}"
                               Foreground="#DC2626"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>