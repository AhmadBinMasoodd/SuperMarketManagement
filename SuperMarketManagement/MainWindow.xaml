<Window x:Class="SuperMarketManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowState="Maximized">

    <Grid>

        <!-- Gradient Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4CAF50" Offset="0"/>
                <GradientStop Color="#2E7D32" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Center Layout -->
        <Grid ShowGridLines="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="2*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Login Card -->
                <Border Grid.Column="1"
                        Padding="30"
                        CornerRadius="15"
                        Background="White"
                        MaxWidth="400">

                    <StackPanel>

                        <!-- Title -->
                        <TextBlock Text="Super Market"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Login to Continue"
                                   FontSize="14"
                                   Foreground="Gray"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <!-- Email -->
                        <TextBlock Text="Email" FontWeight="SemiBold"/>
                        <TextBox x:Name="EmailBox"
                                 Height="35"
                                 Margin="0,5,0,10"
                                 Padding="8"
                                 BorderBrush="#4CAF50"
                                 BorderThickness="1"
                                 Background="#F9F9F9"/>

                        <!-- Password -->
                        <TextBlock Text="Password" FontWeight="SemiBold"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Height="35"
                                     Margin="0,5,0,15"
                                     Padding="8"
                                     BorderBrush="#4CAF50"
                                     BorderThickness="1"
                                     Background="#F9F9F9"/>

                        <!-- Button -->
                        <Button Content="Login"
                                Height="40"
                                Background="#4CAF50"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Cursor="Hand"/>

                        <!-- Error -->
                        <TextBlock x:Name="ErrorText"
                                   Foreground="Red"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>

                    </StackPanel>

                </Border>
            </Grid>
        </Grid>

    </Grid>
</Window>