<UserControl x:Class="SuperMarketManagement.Views.Cashier.DailySummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI">
    <Grid Margin="16">
        <Border Background="White" Padding="24" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Daily Sales Summary" FontSize="24" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,24"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="#F3F0FF" Width="200" Height="100" CornerRadius="8" Padding="16" Margin="0,0,16,0">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Sales" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="$0.00" Foreground="#4C1D95" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#F3F0FF" Width="200" Height="100" CornerRadius="8" Padding="16">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Transactions" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center"/>
                            <TextBlock Text="0" Foreground="#4C1D95" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
