<UserControl x:Class="SuperMarketManagement.Views.Cashier.ReturnRefundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BrushSecondary}"
                Padding="16"
                CornerRadius="12"
                BorderBrush="{StaticResource BrushAccent}"
                BorderThickness="1"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Return &amp; Refund"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushPrimaryText}"/>
                    <TextBlock Text="Search receipt, adjust quantity with +/- and print updated bill."
                               Foreground="{StaticResource BrushSecondaryText}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBox Width="160"
                             Height="36"
                             Margin="0,0,8,0"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Text="{Binding ReceiptNumberText, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Search"
                            Command="{Binding SearchReceiptCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource BrushSecondary}"
                Padding="16"
                CornerRadius="12"
                BorderBrush="{StaticResource BrushAccent}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource BrushSecondaryText}"
                           FontSize="13"/>

                <Grid Grid.Row="1"
                      Margin="0,10,0,10"
                      Visibility="{Binding ReceiptSectionVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding SaleId, StringFormat=Receipt #: {0}}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushPrimaryText}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding CashierName, StringFormat=Cashier: {0}}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding SaleDateTime, StringFormat=Sale Date: {0:g}}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               HorizontalAlignment="Right"/>
                </Grid>

                <DataGrid Grid.Row="2"
                          Visibility="{Binding ReceiptSectionVisibility}"
                          ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="38"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushSelectedRow}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="40"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushButtonHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushSelectedRow}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Width="50" Binding="{Binding SrNo}"/>
                        <DataGridTextColumn Header="Item" Width="*" Binding="{Binding ProductName}"/>
                        <DataGridTextColumn Header="Original Qty" Width="100" Binding="{Binding OriginalQuantity}"/>
                        <DataGridTemplateColumn Header="Adjust" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Width="28"
                                                Height="26"
                                                Margin="0,0,5,0"
                                                Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <Icons:PackIconMaterial Kind="Minus" Width="14" Height="14"/>
                                        </Button>
                                        <Button Width="28"
                                                Height="26"
                                                Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <Icons:PackIconMaterial Kind="Plus" Width="14" Height="14"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="New Qty" Width="80" Binding="{Binding CurrentQuantity}"/>
                        <DataGridTextColumn Header="Unit (PKR)" Width="100" Binding="{Binding UnitPrice, StringFormat={}{0:N2}}"/>
                        <DataGridTextColumn Header="Line Total (PKR)" Width="130" Binding="{Binding LineTotal, StringFormat={}{0:N2}}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="3"
                      Margin="0,10,0,0"
                      Visibility="{Binding ReceiptSectionVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Original Total: " FontWeight="SemiBold" Foreground="{StaticResource BrushSecondaryText}"/>
                        <TextBlock Text="{Binding OriginalTotalAmount, StringFormat=PKR {0:N2}}" FontWeight="Bold" Foreground="{StaticResource BrushPrimaryText}" Margin="0,0,16,0"/>
                        <TextBlock Text="Updated Total: " FontWeight="SemiBold" Foreground="{StaticResource BrushSecondaryText}"/>
                        <TextBlock Text="{Binding UpdatedTotalAmount, StringFormat=PKR {0:N2}}" FontWeight="Bold" Foreground="{StaticResource BrushPrimaryText}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Apply Changes and Print"
                            Command="{Binding ApplyAndPrintCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>