<Window x:Class="SuperMarketManagement.Views.Cashier.CashierDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:SuperMarketManagement.Views.Cashier"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        AllowsTransparency="False"
        Background="{StaticResource BrushPrimaryDark}"
        Title="CashierDashboard"
        Height="760"
        Width="1280"
        MinHeight="560"
        MinWidth="920">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
            <Style x:Key="AppBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="{StaticResource BrushSecondaryText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource BrushButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource BrushSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

            <Style x:Key="SideMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="{StaticResource BrushSecondary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MenuBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuBorder" Property="Background" Value="{StaticResource BrushSecondary}"/>
                                <Setter TargetName="MenuBorder" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuBorder" Property="Background" Value="{StaticResource BrushSecondary}"/>
                                <Setter TargetName="MenuBorder" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideMenuButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BrushSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
            <Setter Property="Background" Value="{StaticResource BrushSecondary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushButtonHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrushButtonHover}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="30" Background="{StaticResource BrushPrimaryDark}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="240" MaxWidth="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Height="74"
                    CornerRadius="30,30,0,0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1">
                <Border Background="{StaticResource HeaderGradient}"
                        CornerRadius="30,30,0,0" HorizontalAlignment="Left" Width="1280">
                    <DockPanel Margin="18,0,14,0" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                <Border Width="40"
                                    Height="40"
                                    Background="{StaticResource BrushButtonHover}"
                                    CornerRadius="12"
                                    Margin="0,0,12,0">
                                <Icons:PackIconMaterial Kind="StorefrontOutline"
                                                        Width="22"
                                                        Height="22"
                                            Foreground="{StaticResource BrushAccent}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                            </Border>

                            <StackPanel>
                                <TextBlock Text="SuperStore Management"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushPrimaryText}"/>
                                <TextBlock Text="Cashier Dashboard"
                                           FontSize="12"
                                           Foreground="{StaticResource BrushSecondaryText}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                    </DockPanel>
                </Border>
            </Border>

                <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="{StaticResource BrushAccent}"
                    CornerRadius="0,50,0,30"
                    Margin="0,0,0,0"
                    Padding="16,16,12,16">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                        <TextBlock Text="{Binding CashierName}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource BrushPrimaryText}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding CashierRole}"
                                   Margin="0,3,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushSecondaryText}"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Bottom"
                            Command="{Binding LogoutCommand}"
                            Height="44"
                            Margin="0,12,0,0"
                            BorderThickness="1"
                            HorizontalContentAlignment="Left"
                            Padding="12,0"
                            Style="{StaticResource LogoutButtonStyle}">
                        <DockPanel>
                            <Icons:PackIconMaterial Kind="Logout" Width="18" Height="18" Foreground="{StaticResource BrushPrimaryText}" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" Foreground="{StaticResource BrushPrimaryText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </DockPanel>
                    </Button>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="MENU"
                                           Foreground="{StaticResource BrushButtonHover}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,8"/>

                            <Button Name="POSBtn" Command="{Binding NavigatePosCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}" Value="POS">
                                                <Setter Property="Background" Value="{StaticResource BrushSecondary}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel>
                                    <Icons:PackIconMaterial Kind="CashRegister" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,10,0"/>
                                    <TextBlock Text="Point of Sale" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </DockPanel>
                            </Button>

                            <Button Name="ReturnRefundBtn" Command="{Binding NavigateReturnRefundCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}" Value="ReturnRefund">
                                                <Setter Property="Background" Value="{StaticResource BrushSecondary}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel>
                                    <Icons:PackIconMaterial Kind="CashRefund" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,10,0"/>
                                    <TextBlock Text="Return / Refund" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>

                            <Button Name="DailySummaryBtn" Command="{Binding NavigateDailySummaryCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}" Value="DailySummary">
                                                <Setter Property="Background" Value="{StaticResource BrushSecondary}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel>
                                    <Icons:PackIconMaterial Kind="ChartBox" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,10,0"/>
                                    <TextBlock Text="Daily Summary" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>

                            <Button Name="ProfileBtn" Command="{Binding NavigateProfileCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}" Value="Profile">
                                                <Setter Property="Background" Value="{StaticResource BrushSecondary}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel>
                                    <Icons:PackIconMaterial Kind="Account" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,10,0"/>
                                    <TextBlock Text="My Profile" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Margin="16"
                    Padding="18"
                    Background="{StaticResource BrushSecondary}"
                    CornerRadius="14">
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>

            <GridSplitter Grid.Row="1"
                          Grid.Column="0"
                          Width="5"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource BrushAccent}"
                          ResizeDirection="Columns"
                          ResizeBehavior="CurrentAndNext"
                          ShowsPreview="True"/>
        </Grid>
    </Border>
</Window>
