<UserControl x:Class="SuperMarketManagement.Views.Admin.ChartOverview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SuperMarketManagement.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="980"
             Background="Transparent">
	<UserControl.Resources>
		<DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="3" Opacity="0.12" Color="#0F172A"/>

		<Style x:Key="CardBorderStyle" TargetType="Border">
			<Setter Property="Background" Value="White"/>
			<Setter Property="CornerRadius" Value="22"/>
			<Setter Property="BorderBrush" Value="#E2E8F0"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
			<Setter Property="Padding" Value="18"/>
		</Style>

		<Style x:Key="SectionTitleStyle" TargetType="TextBlock">
			<Setter Property="FontSize" Value="16"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="Foreground" Value="#0F172A"/>
		</Style>

		<Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
			<Setter Property="FontSize" Value="12"/>
			<Setter Property="Foreground" Value="#64748B"/>
		</Style>

		<DataTemplate x:Key="MetricCardTemplate">
			<Border CornerRadius="18"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Padding="16"
                    Effect="{StaticResource SoftShadow}">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="10"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="6"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<Border Width="44"
                            Height="44"
                            CornerRadius="14"
                            Background="{Binding Accent}"
                            HorizontalAlignment="Left">
						<TextBlock Text="■"
                                   Foreground="White"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
					</Border>

					<TextBlock Grid.Row="2"
                               Text="{Binding Value}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#0F172A"/>

					<TextBlock Grid.Row="3"
                               Text="{Binding Title}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#334155"/>

					<TextBlock Grid.Row="4"
                               Text="{Binding Description}"
                               FontSize="12"
                               Foreground="#64748B"
                               TextWrapping="Wrap"/>
				</Grid>
			</Border>
		</DataTemplate>

		<DataTemplate x:Key="RecentSaleTemplate">
			<Border Padding="14"
                    CornerRadius="14"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Margin="0,0,0,10">
				<StackPanel>
					<TextBlock Text="{Binding SaleId, StringFormat=Receipt #{0}}"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"/>
					<TextBlock Text="{Binding CashierName}"
                               FontSize="12"
                               Foreground="#64748B"
                               Margin="0,2,0,0"/>
					<TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N2}}"
                               FontWeight="Bold"
                               Foreground="#16A34A"
                               Margin="0,6,0,0"/>
					<TextBlock Text="{Binding SaleDateTime, StringFormat={}{0:dd MMM yyyy, hh:mm tt}}"
                               FontSize="12"
                               Foreground="#64748B"
                               Margin="0,2,0,0"/>
				</StackPanel>
			</Border>
		</DataTemplate>
	</UserControl.Resources>

	<Grid Background="#F5F7FB">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="18"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="18"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<!-- Hero Banner -->
		<Border CornerRadius="28"
                Padding="26"
                Effect="{StaticResource SoftShadow}">
			<Border.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#0F172A" Offset="0"/>
					<GradientStop Color="#1E293B" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="280"/>
				</Grid.ColumnDefinitions>

				<StackPanel>
					<TextBlock Text="{Binding WelcomeMessage}"
                               Foreground="#C7D2FE"
                               FontSize="13"
                               FontWeight="SemiBold"/>
					<TextBlock Text="Operations dashboard"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               Margin="0,6,0,8"/>
					<TextBlock Text="{Binding Subtitle}"
                               Foreground="#CBD5E1"
                               FontSize="13"
                               MaxWidth="620"
                               TextWrapping="Wrap"/>

					<StackPanel Orientation="Horizontal" Margin="0,18,0,0">
						<Border Padding="12,8" CornerRadius="999" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Margin="0,0,10,0">
							<TextBlock Foreground="White" FontWeight="SemiBold" Text="Live sales"/>
						</Border>
						<Border Padding="12,8" CornerRadius="999" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" Margin="0,0,10,0">
							<TextBlock Foreground="White" FontWeight="SemiBold" Text="Stock health"/>
						</Border>
						<Border Padding="12,8" CornerRadius="999" Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
							<TextBlock Foreground="White" FontWeight="SemiBold" Text="Recent activity"/>
						</Border>
					</StackPanel>
				</StackPanel>

				<Border Grid.Column="1"
                        CornerRadius="22"
                        Background="#111827"
                        Padding="18"
                        BorderBrush="#334155"
                        BorderThickness="1">
					<StackPanel>
						<TextBlock Text="Revenue snapshot" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold"/>
						<TextBlock Text="{Binding HeroStat}"
                                   Foreground="White"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Margin="0,6,0,4"/>
						<TextBlock Text="Current total revenue across all sales." Foreground="#CBD5E1" FontSize="12" TextWrapping="Wrap"/>
					</StackPanel>
				</Border>
			</Grid>
		</Border>

		<!-- Metric Cards Row -->
		<ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<UniformGrid Columns="3"/>
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<StaticResource ResourceKey="MetricCardTemplate"/>
			</ItemsControl.ItemTemplate>
			<ItemsControl.Resources>
				<Style TargetType="ContentPresenter">
					<Setter Property="Margin" Value="0,0,12,12"/>
				</Style>
			</ItemsControl.Resources>
		</ItemsControl>

		<!-- Recent Sales Card (full width) -->
		<Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="16"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<StackPanel>
					<TextBlock Text="Recent Sales" Style="{StaticResource SectionTitleStyle}"/>
					<TextBlock Text="Latest completed receipts and revenue flow"
                               Style="{StaticResource SectionSubtitleStyle}"
                               Margin="0,4,0,0"/>
				</StackPanel>

				<Border Grid.Row="2"
                        Background="#F8FAFC"
                        CornerRadius="18"
                        Padding="16"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
					<ListView ItemsSource="{Binding RecentSales}"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ItemTemplate="{StaticResource RecentSaleTemplate}">
						<ListView.ItemContainerStyle>
							<Style TargetType="ListViewItem">
								<Setter Property="Padding" Value="0"/>
								<Setter Property="Margin" Value="0"/>
								<Setter Property="BorderThickness" Value="0"/>
								<Setter Property="Background" Value="Transparent"/>
								<Setter Property="Focusable" Value="False"/>
							</Style>
						</ListView.ItemContainerStyle>
					</ListView>
				</Border>
			</Grid>
		</Border>

	</Grid>
</UserControl>