<UserControl x:Class="SuperMarketManagement.Views.Admin.StockHistory"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             FontFamily="Segoe UI"
             d:DesignHeight="650" d:DesignWidth="980">
    <Grid Margin="8">
        <Border Background="{StaticResource BrushSecondary}"
            Padding="16"
            CornerRadius="14"
            BorderBrush="{StaticResource BrushAccent}"
            BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Stock History"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushPrimaryText}"/>
                        <TextBlock Text="View all stock additions and subtractions"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBox x:Name="SearchTextBox"
                             DockPanel.Dock="Right"
                             Width="230"
                             Height="34"
                             FontSize="13"
                             VerticalAlignment="Center"
                             Padding="8,6,8,6"
                             Background="{StaticResource BrushSecondary}"
                             BorderBrush="{StaticResource BrushAccent}"
                             BorderThickness="1"
                             Foreground="{StaticResource BrushPrimaryText}"
                             ToolTip="Search by product, user, or type"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>

                <DataGrid Grid.Row="2"
                          x:Name="HistoryDataGrid"
                          Background="{StaticResource BrushPrimaryDark}"
                          FontSize="14"
                          GridLinesVisibility="Horizontal"
                          RowBackground="{StaticResource BrushSecondary}"
                          AlternatingRowBackground="{StaticResource BrushAltRow}"
                          RowHeaderWidth="0"
                          BorderThickness="1"
                          BorderBrush="{StaticResource BrushAccent}"
                          HorizontalGridLinesBrush="{StaticResource BrushAccent}"
                          VerticalGridLinesBrush="{StaticResource BrushAccent}"
                          SelectionUnit="FullRow"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          ItemsSource="{Binding History}">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="40"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushSelectedRow}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="40"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushButtonHover}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding TransactionDateTime, StringFormat={}{0:g}}" Width="140"/>
                        <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="150"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding TransactionType}" Width="80"/>
                        <DataGridTextColumn Header="Quantity" Binding="{Binding QuantityChanged}" Width="80"/>
                        <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
