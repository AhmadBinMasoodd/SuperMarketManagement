<UserControl x:Class="SuperMarketManagement.Views.Admin.Category"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:SuperMarketManagement.Views.Admin"
             mc:Ignorable="d" 
             FontFamily="Segoe UI"
             d:DesignHeight="650" d:DesignWidth="980">
    <UserControl.Resources>
        <StaticResource x:Key="PrimaryBrush" ResourceKey="BrushAccent" />
        <StaticResource x:Key="PrimaryLightBrush" ResourceKey="BrushButtonHover" />
        <StaticResource x:Key="SurfaceBrush" ResourceKey="BrushSecondary" />
        <StaticResource x:Key="TextPrimaryBrush" ResourceKey="BrushPrimaryText" />
        <StaticResource x:Key="TextSecondaryBrush" ResourceKey="BrushSecondaryText" />

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource BrushButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource BrushAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridDeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DeleteBtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DeleteBtnBorder" Property="Background" Value="{StaticResource BrushButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="DeleteBtnBorder" Property="Background" Value="{StaticResource BrushSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                Padding="16"
                CornerRadius="12"
                BorderBrush="{StaticResource BrushAccent}"
                BorderThickness="1"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="5"
                        Background="{StaticResource BrushButtonHover}"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Category Management"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Manage category names and descriptions"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="Category Name" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="CategoryNameTextBox" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Padding="8,6,8,6" Background="{StaticResource BrushSecondary}" BorderBrush="{StaticResource BrushAccent}" Foreground="{StaticResource BrushPrimaryText}"/>
                </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="Description" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="CategoryDescriptionTextBox" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" MaxLength="50" Padding="8,6,8,6" Background="{StaticResource BrushSecondary}" BorderBrush="{StaticResource BrushAccent}" Foreground="{StaticResource BrushPrimaryText}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="4" VerticalAlignment="Bottom" Margin="0,0,0,4">
                    <CheckBox x:Name="IsActiveCheckBox" Content="Active" IsChecked="{Binding IsActive}" FontWeight="SemiBold" Foreground="{StaticResource BrushPrimaryText}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,10,0,0">
                    <Button x:Name="AddCategoryButton" Style="{StaticResource ActionButtonStyle}" Content="Add" Width="96" Margin="0,0,8,0" Command="{Binding AddCommand}"/>
                    <Button x:Name="UpdateCategoryButton" Style="{StaticResource ActionButtonStyle}" Content="Update" Width="96" Command="{Binding UpdateCommand}"/>
                    <Button x:Name="ClearButton" Style="{StaticResource ActionButtonStyle}" Content="Clear" Width="96" Margin="8,0,0,0" Command="{Binding ClearCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
            Background="{StaticResource BrushSecondary}"
            Padding="10"
            CornerRadius="12"
            BorderBrush="{StaticResource BrushAccent}"
            BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Category List"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushPrimaryText}"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="SearchTextBox"
                             DockPanel.Dock="Right"
                             Width="230"
                             Height="34"
                             FontSize="13"
                             VerticalAlignment="Center"
                              ToolTip="Search by category name or description"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </DockPanel>

                <DataGrid Grid.Row="2"
                          x:Name="CategoryDataGrid"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                          Background="White"
                          FontSize="14"
                          GridLinesVisibility="Horizontal"
                          RowBackground="{StaticResource BrushSecondary}"
                          AlternatingRowBackground="{StaticResource BrushAltRow}"
                          RowHeaderWidth="0"
                          BorderThickness="0"
                          HorizontalGridLinesBrush="{StaticResource BrushAccent}"
                          VerticalGridLinesBrush="{StaticResource BrushAccent}"
                          SelectionUnit="FullRow"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="40"/>
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushSelectedRow}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="42"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushButtonHover}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushSelectedRow}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="100">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Setter Property="Focusable" Value="False"/>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                        </DataGridCheckBoxColumn>
                        <DataGridTemplateColumn Header="Delete" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource GridDeleteButtonStyle}" 
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Id}">
                                        <Icons:PackIconMaterial Kind="Delete" Width="16" Height="16" Foreground="White"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
