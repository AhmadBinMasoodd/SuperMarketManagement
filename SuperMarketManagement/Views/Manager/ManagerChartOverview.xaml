<UserControl x:Class="SuperMarketManagement.Views.Manager.ManagerChartOverview"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SuperMarketManagement.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="980"
             Background="Transparent">
    <UserControl.Resources>
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="10" ShadowDepth="2" Opacity="0.10" Color="#0F172A"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushSecondary}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource SoftShadow}"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryText}"/>
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource BrushSecondaryText}"/>
        </Style>

        <DataTemplate x:Key="MetricCardTemplate">
            <Border CornerRadius="14"
                    Background="{StaticResource BrushSecondary}"
                    BorderBrush="{StaticResource BrushAccent}"
                    BorderThickness="1"
                    Padding="12"
                    Effect="{StaticResource SoftShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Width="34"
                            Height="34"
                            CornerRadius="10"
                            Background="{Binding Accent}"
                            HorizontalAlignment="Left">
                        <TextBlock Text="■"
                                   Foreground="{StaticResource BrushPrimaryText}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Row="2"
                               Text="{Binding Value}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushPrimaryText}"/>

                    <TextBlock Grid.Row="4"
                               Text="{Binding Title}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushSecondaryText}"/>

                    <TextBlock Grid.Row="6"
                               Text="{Binding Description}"
                               FontSize="10"
                               Foreground="{StaticResource BrushSecondaryText}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StockMovementTemplate">
            <Border Padding="10"
                    CornerRadius="10"
                    Background="{StaticResource BrushSecondary}"
                    BorderBrush="{StaticResource BrushAccent}"
                    BorderThickness="1"
                    Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding ProductName}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushPrimaryText}"/>
                        <TextBlock Text="{Binding UserName}"
                                   FontSize="11"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding Remarks}"
                                   FontSize="10"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding QuantityChanged, StringFormat={}{0:N0}}"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Foreground="{StaticResource BrushSelectedRow}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding TransactionType}"
                                   FontSize="10"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0"/>
                        <TextBlock Text="{Binding TransactionDateTime, StringFormat={}{0:dd MMM yyyy, hh:mm tt}}"
                                   FontSize="10"
                                   Foreground="{StaticResource BrushSecondaryText}"
                                   HorizontalAlignment="Right"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource BrushPrimaryDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border CornerRadius="20"
                Padding="18"
                Effect="{StaticResource SoftShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1E293B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding WelcomeMessage}"
                               Foreground="{StaticResource BrushSecondaryText}"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Inventory dashboard"
                               Foreground="{StaticResource BrushPrimaryText}"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,4,0,4"/>
                    <TextBlock Text="{Binding Subtitle}"
                               Foreground="{StaticResource BrushSecondaryText}"
                               FontSize="11"
                               MaxWidth="500"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border Padding="10,5" CornerRadius="999" Background="{StaticResource BrushSecondary}" BorderBrush="{StaticResource BrushAccent}" BorderThickness="1" Margin="0,0,8,0">
                            <TextBlock Foreground="{StaticResource BrushPrimaryText}" FontSize="11" FontWeight="SemiBold" Text="Stock movement"/>
                        </Border>
                        <Border Padding="10,5" CornerRadius="999" Background="{StaticResource BrushSecondary}" BorderBrush="{StaticResource BrushAccent}" BorderThickness="1" Margin="0,0,8,0">
                            <TextBlock Foreground="{StaticResource BrushPrimaryText}" FontSize="11" FontWeight="SemiBold" Text="Low stock watch"/>
                        </Border>
                        <Border Padding="10,5" CornerRadius="999" Background="{StaticResource BrushSecondary}" BorderBrush="{StaticResource BrushAccent}" BorderThickness="1">
                            <TextBlock Foreground="{StaticResource BrushPrimaryText}" FontSize="11" FontWeight="SemiBold" Text="Catalog health"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                    <Border Grid.Column="1"
                        CornerRadius="16"
                        Background="{StaticResource BrushSecondary}"
                        Padding="14"
                        BorderBrush="{StaticResource BrushAccent}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Inventory snapshot" Foreground="{StaticResource BrushSecondaryText}" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding HeroStat}"
                                   Foreground="{StaticResource BrushPrimaryText}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,4,0,2"/>
                        <TextBlock Text="Items needing attention right now." Foreground="{StaticResource BrushSecondaryText}" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="2" ItemsSource="{Binding Metrics}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <StaticResource ResourceKey="MetricCardTemplate"/>
            </ItemsControl.ItemTemplate>
            <ItemsControl.Resources>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Margin" Value="0,0,10,0"/>
                </Style>
            </ItemsControl.Resources>
        </ItemsControl>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="0.85*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Recent Stock Movements" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Latest inventory changes recorded by the system"
                                   Style="{StaticResource SectionSubtitleStyle}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                        <Border Grid.Row="2"
                            Background="{StaticResource BrushSecondary}"
                            CornerRadius="12"
                            Padding="10"
                            BorderBrush="{StaticResource BrushAccent}"
                            BorderThickness="1">
                        <ListView ItemsSource="{Binding RecentStockMovements}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ItemTemplate="{StaticResource StockMovementTemplate}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Focusable" Value="False"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Grid.Column="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Low Stock Watchlist" Style="{StaticResource SectionTitleStyle}"/>
                        <TextBlock Text="Products at or below the warning threshold"
                                   Style="{StaticResource SectionSubtitleStyle}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                        <Border Grid.Row="2"
                            Background="{StaticResource BrushSecondary}"
                            CornerRadius="12"
                            Padding="10"
                            BorderBrush="{StaticResource BrushAccent}"
                            BorderThickness="1">
                        <ListView ItemsSource="{Binding LowStockItems}"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                        <Border Padding="10"
                                            CornerRadius="10"
                                            Background="{StaticResource BrushSecondary}"
                                            BorderBrush="{StaticResource BrushAccent}"
                                            BorderThickness="1"
                                            Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource BrushPrimaryText}"/>
                                                <TextBlock Text="{Binding Quantity, StringFormat={}{0:N0} units left}" FontSize="10" Foreground="{StaticResource BrushSecondaryText}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding SalePrice, StringFormat=PKR {0:N2}}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource BrushSelectedRow}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding PurchasePrice, StringFormat=Cost {0:N2}}" FontSize="10" Foreground="{StaticResource BrushSecondaryText}" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>