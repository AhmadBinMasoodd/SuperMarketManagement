<Window x:Class="SuperMarketManagement.Views.Manager.ManagerDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:SuperMarketManagement.Views.Manager"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        AllowsTransparency="False"
        Background="#EFF2F7"
        Title="ManagerDashboard"
        Height="760"
        Width="1280"
        MinHeight="560"
        MinWidth="920">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="AppBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource AppBarButtonStyle}">
            <Setter Property="Foreground" Value="#64748B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#DC2626"/>
                    <Setter Property="Background" Value="#FEE2E2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FECACA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SideMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#7C5AE5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#EDE9FE"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MenuBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuBorder" Property="Background" Value="#8B6AF1"/>
                                <Setter TargetName="MenuBorder" Property="BorderBrush" Value="#C4B5FD"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuBorder" Property="Background" Value="#4C1D95"/>
                                <Setter TargetName="MenuBorder" Property="BorderBrush" Value="#A78BFA"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideMenuButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
            <Setter Property="Background" Value="#7C5AE5"/>
            <Setter Property="BorderBrush" Value="#C4B5FD"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="30" Background="#EFF2F7">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="240" MaxWidth="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Height="74"
                    CornerRadius="30,30,0,0"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1">
                <Border Background="#FFFFFF"
                        CornerRadius="30,30,0,0" HorizontalAlignment="Left" Width="1280">
                    <DockPanel Margin="18,0,14,0" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="40"
                                    Height="40"
                                    Background="#F1EDFF"
                                    CornerRadius="12"
                                    Margin="0,0,12,0">
                                <Icons:PackIconMaterial Kind="StorefrontOutline"
                                                        Width="22"
                                                        Height="22"
                                                        Foreground="#623ED0"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                            </Border>

                            <StackPanel>
                                <TextBlock Text="SuperStore Management"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#1E293B"/>
                                <TextBlock Text="Manager Dashboard"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button DockPanel.Dock="Right"
                                Name="CloseBtn"
                                Click="CloseBtn_Click"
                                Style="{StaticResource AppBarCloseButtonStyle}"
                                VerticalAlignment="Center">
                            <Icons:PackIconMaterial Kind="Close"
                                                    Width="16"
                                                    Height="16"
                                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                    </DockPanel>
                </Border>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="#623ED0"
                    CornerRadius="0,50,0,30"
                    Margin="0,0,0,0"
                    Padding="16,16,12,16">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                        <TextBlock Text="{Binding ManagerName}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ManagerRole}"
                                   Margin="0,3,0,0"
                                   FontSize="12"
                                   Foreground="#DDD6FE"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Bottom"
                            Command="{Binding LogoutCommand}"
                            Height="44"
                            Margin="0,12,0,0"
                            Background="#5B21B6"
                            BorderBrush="#A78BFA"
                            BorderThickness="1"
                            HorizontalContentAlignment="Left"
                            Padding="12,0">
                        <DockPanel>
                            <Icons:PackIconMaterial Kind="Logout" Width="18" Height="18" Foreground="White" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </DockPanel>
                    </Button>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="MENU"
                                       Foreground="#C4B5FD"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,8"/>

                            <Button Name="DashboardButton" Command="{Binding NavigateDashboardCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}" Value="Dashboard">
                                                <Setter Property="Background" Value="#7C5AE5"/>
                                                <Setter Property="BorderBrush" Value="#C4B5FD"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel>
                                    <Icons:PackIconMaterial Kind="ViewDashboard" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,10,0"/>
                                    <TextBlock Text="Dashboard" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                </DockPanel>
                            </Button>

                            <Button Name="CategoryButton" Command="{Binding NavigateCategoryCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}" Value="Category">
                                                <Setter Property="Background" Value="#7C5AE5"/>
                                                <Setter Property="BorderBrush" Value="#C4B5FD"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel>
                                    <Icons:PackIconMaterial Kind="Cart" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,10,0"/>
                                    <TextBlock Text="Categories" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>

                            <Button Name="ProductBtn" Command="{Binding NavigateProductCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}" Value="Product">
                                                <Setter Property="Background" Value="#7C5AE5"/>
                                                <Setter Property="BorderBrush" Value="#C4B5FD"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel>
                                    <Icons:PackIconMaterial Kind="PackageVariantClosed" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,10,0"/>
                                    <TextBlock Text="Products" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>

                            <Button Name="StockHistoryBtn" Command="{Binding NavigateStockHistoryCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SideMenuButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActiveMenu}" Value="StockHistory">
                                                <Setter Property="Background" Value="#7C5AE5"/>
                                                <Setter Property="BorderBrush" Value="#C4B5FD"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <DockPanel>
                                    <Icons:PackIconMaterial Kind="History" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,10,0"/>
                                    <TextBlock Text="Stock History" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Margin="16"
                    Padding="18"
                    Background="White"
                    CornerRadius="14">
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>


            <GridSplitter Grid.Row="1"
                          Grid.Column="0"
                          Width="5"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Stretch"
                          Background="#C7D2FE"
                          ResizeDirection="Columns"
                          ResizeBehavior="CurrentAndNext"
                          ShowsPreview="True"/>
        </Grid>
    </Border>
</Window>
